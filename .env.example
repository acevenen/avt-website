# Stripe Payment Links (public by design, so NEXT_PUBLIC_ is correct).
# Set the same three in Vercel -> Project -> Settings -> Environment Variables,
# then redeploy — these are inlined at build time.
NEXT_PUBLIC_STRIPE_SIGNALS=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_AUTOPILOT=https://buy.stripe.com/...
NEXT_PUBLIC_STRIPE_COURSE=https://buy.stripe.com/...
