# ── AVT site environment ─────────────────────────────────────────────────────
# Copy to .env.local for local dev. In production set these in
# Vercel → Project → Settings → Environment Variables, then redeploy.
# NEVER commit real values.

# Stripe (required for selling the Course + Coaching)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Neon Postgres — student accounts, credentials, belt progress (free tier)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: pins the origin used for Stripe redirect URLs.
# Vercel sets VERCEL_URL automatically, so this is only needed for a custom domain.
NEXT_PUBLIC_SITE_URL=https://avt-website.vercel.app
